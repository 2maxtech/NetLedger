# Copy to .env on the deployment host. Never commit the real file.
# docker compose reads .env automatically from the project root.

# Postgres password this DB was initialized with. DO NOT change on an
# existing deploy — altering this without also ALTERing the netbill user
# in Postgres will break the backend. On a fresh deploy, set whatever you
# want (but do not use "netbill").
DB_PASSWORD=<your-db-password>
